PORT=4242
CORS_ORIGIN=*

# Data storage
# Use file for local development/demo mode. Use mysql for hospital deployment.
DB_PROVIDER=file
STATE_FILE_PATH=backend/data/queue-state.json
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=waitless_db
DB_USER=waitless
DB_PASSWORD=
DB_CONNECTION_LIMIT=10
DB_SEED_DEMO_DATA=true

# Staff access
# Replace these demo credentials before any real deployment.
AUTH_SESSION_TTL_MS=28800000
STAFF_USERS_JSON=[{"id":"admin","username":"admin","password":"admin123","name":"System Administrator","role":"admin"},{"id":"reception","username":"reception","password":"reception123","name":"Reception Desk","role":"reception"},{"id":"triage","username":"triage","password":"triage123","name":"Triage Nurse","role":"triage"},{"id":"clinician","username":"clinician","password":"clinician123","name":"Clinical Desk","role":"clinician"}]

# Notification transport
WHATSAPP_PROVIDER=mock
WHATSAPP_RETRY_DELAYS_MS=15000,60000,300000
WHATSAPP_MOCK_DELAY_MS=250
WHATSAPP_MOCK_FAILURE_RATE=0

# Meta WhatsApp Cloud API
# Switch WHATSAPP_PROVIDER to meta-cloud to enable live sends.
WHATSAPP_API_BASE_URL=https://graph.facebook.com
WHATSAPP_API_VERSION=v23.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_REQUEST_TIMEOUT_MS=10000

# Optional template names. If left blank, the integration falls back to text messages.
WHATSAPP_TEMPLATE_LANGUAGE=en_US
WHATSAPP_TEMPLATE_QUEUE_REGISTERED=
WHATSAPP_TEMPLATE_QUEUE_READY_SOON=
WHATSAPP_TEMPLATE_QUEUE_CALLED=
